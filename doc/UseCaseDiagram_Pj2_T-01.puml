@startuml
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor LightGreen
  BorderColor Black
}

actor "Scheduling Committee Member" as SCM
actor "Scheduling Coordinator" as SC

rectangle "Bellini Classes System" {
  usecase "Upload Excel File" as UC_UPLOAD
  usecase "Remove Uploaded File" as UC_REMOVE
  usecase "Search and Filter Classes" as UC_SEARCH
  usecase "Compare Semester Schedules" as UC_COMPARE
  usecase "View Instructor Schedule" as UC_INSTRUCTOR
  usecase "Vacancy Search" as UC_VACANCY

  usecase "View Room Schedule" as UC_ROOM #LightYellow
  usecase "Detect Scheduling Conflicts" as UC_CONFLICT #LightYellow
  usecase "Validate Uploaded File" as UC_VALIDATE #LightYellow
  usecase "Detect Duplicate Upload File" as UC_DUP_FILE #LightYellow
  usecase "View Class Details" as UC_DETAILS #LightYellow
  usecase "View Semester Statistics" as UC_STATS #LightYellow
}

SCM -- UC_UPLOAD
SCM -- UC_REMOVE
SCM -- UC_SEARCH
SCM -- UC_COMPARE
SCM -- UC_INSTRUCTOR
SC -- UC_VACANCY

UC_UPLOAD ..> UC_VALIDATE : <<include>>
UC_UPLOAD ..> UC_DUP_FILE : <<include>>
UC_INSTRUCTOR ..> UC_CONFLICT : <<include>>
UC_INSTRUCTOR ..> UC_DETAILS : <<include>>
UC_COMPARE ..> UC_STATS : <<include>>
UC_VACANCY ..> UC_ROOM : <<include>>

legend right
|= Color |= Meaning |
|<back:LightGreen>LightGreen</back>|Documented use case|
|<back:LightYellow>LightYellow</back>|Inferred use case|
endlegend

note bottom
User Story -> Use Case Mapping
US1: Upload/import schedule data -> Upload Excel File, Validate Uploaded File, Detect Duplicate Upload File
US2: Search and filter classes -> Search and Filter Classes
US3: Room weekly timetable -> View Room Schedule
US4: Instructor weekly schedule -> View Instructor Schedule, Detect Scheduling Conflicts
US5: Vacancy search -> Vacancy Search
US6: Compare semester schedules -> Compare Semester Schedules, View Semester Statistics
US8: Export schedule -> handled by schedule export routes
end note
@enduml
