@startuml
|Scheduling Committee Member|
start
:Open Instructor Weekly Schedule;
:Select semester;

|System|
:Load instructors for selected semester;
if (Any instructors available?) then (yes)
else (no)
  :Show empty instructor list;
  :Prompt user to choose another semester;
  |Scheduling Committee Member|
  :Select another semester;
  stop
endif

|Scheduling Committee Member|
:Select instructor;
:Click View Schedule;

|System|
:Load classes for selected
instructor + semester;
:Parse meeting days/times;

if (Any classes with valid day/time?) then (yes)
  :Build weekly timetable grid;
else (no)
  :Show "No classes scheduled"
  message;
  |Scheduling Committee Member|
  :Review no-classes result;
  stop
endif

if (Overlapping times on same day?) then (yes)
  :For each overlapping pair;
  if (Same CRN?) then (yes)
    :Ignore pair
    (duplicate same class);
  else (no)
    if (Cross-listed UG/GR
    same course name?) then (yes)
      :Ignore pair
      (valid cross-list);
    else (no)
      :Record conflict;
    endif
  endif
else (no)
endif

:Render timetable +
conflict status;

|Scheduling Committee Member|
:Review schedule/conflicts;
stop
@enduml
